{
  "name": "vscode-ai-config-jumper",
  "displayName": "AI Config Jumper",
  "description": "Quickly find and open AI-related config files and directories in the current workspace.",
  "version": "0.0.1",
  "publisher": "neorrrr",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoRrrr/vscode-ai-config-jumper.git"
  },
  "bugs": {
    "url": "https://github.com/NeoRrrr/vscode-ai-config-jumper/issues"
  },
  "homepage": "https://github.com/NeoRrrr/vscode-ai-config-jumper#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aiConfigJumper.configs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiConfigJumper.refresh",
        "title": "Refresh AI Configs",
        "icon": "$(refresh)"
      },
      {
        "command": "aiConfigJumper.revealDirectory",
        "title": "Reveal Directory in Explorer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiConfigJumper.refresh",
          "when": "view == aiConfigJumper.configs",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiConfigJumper",
          "title": "AI Configs",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "aiConfigJumper": [
        {
          "id": "aiConfigJumper.configs",
          "name": "AI Configs"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.5.2"
  }
}
