{
  "name": "vscode-ai-config-jumper",
  "displayName": "AI Config Jumper",
  "description": "在 VS Code 侧边栏快速查看并跳转当前工作区里的 AI 配置文件和目录。",
  "version": "0.0.6",
  "publisher": "neorrrr",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoRrrr/vscode-ai-config-jumper.git"
  },
  "bugs": {
    "url": "https://github.com/NeoRrrr/vscode-ai-config-jumper/issues"
  },
  "homepage": "https://github.com/NeoRrrr/vscode-ai-config-jumper#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aiConfigJumper.configs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "AI Config Jumper",
      "properties": {
        "aiConfigJumper.showSystemConfigs": {
          "type": "boolean",
          "default": false,
          "description": "Show user/system-level AI configuration files and directories, such as ~/.codex, ~/.claude, ~/.gemini, ~/.cursor, and global MCP config files."
        }
      }
    },
    "commands": [
      {
        "command": "aiConfigJumper.refresh",
        "title": "Refresh AI Configs",
        "icon": "$(refresh)"
      },
      {
        "command": "aiConfigJumper.revealDirectory",
        "title": "Reveal Directory in Explorer"
      },
      {
        "command": "aiConfigJumper.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "aiConfigJumper.openToSide",
        "title": "Open to the Side",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "aiConfigJumper.copyPath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "aiConfigJumper.copyRelativePath",
        "title": "Copy Relative Path",
        "icon": "$(copy)"
      },
      {
        "command": "aiConfigJumper.revealInExplorer",
        "title": "Reveal in Explorer",
        "icon": "$(reveal)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiConfigJumper.refresh",
          "when": "view == aiConfigJumper.configs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aiConfigJumper.revealDirectory",
          "when": "view == aiConfigJumper.configs && viewItem == directory",
          "group": "navigation"
        },
        {
          "command": "aiConfigJumper.revealDirectory",
          "when": "view == aiConfigJumper.configs && viewItem == fsDirectory",
          "group": "navigation"
        },
        {
          "command": "aiConfigJumper.openFile",
          "when": "view == aiConfigJumper.configs && viewItem =~ /^(file|fsFile)$/",
          "group": "navigation@1"
        },
        {
          "command": "aiConfigJumper.openToSide",
          "when": "view == aiConfigJumper.configs && viewItem =~ /^(file|fsFile)$/",
          "group": "navigation@2"
        },
        {
          "command": "aiConfigJumper.revealInExplorer",
          "when": "view == aiConfigJumper.configs && viewItem =~ /^(file|fsFile)$/",
          "group": "navigation@3"
        },
        {
          "command": "aiConfigJumper.copyPath",
          "when": "view == aiConfigJumper.configs && viewItem =~ /^(file|directory|fsFile|fsDirectory)$/",
          "group": "navigation@4"
        },
        {
          "command": "aiConfigJumper.copyRelativePath",
          "when": "view == aiConfigJumper.configs && viewItem =~ /^(file|directory|fsFile|fsDirectory)$/",
          "group": "navigation@5"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiConfigJumper",
          "title": "AI Configs",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "aiConfigJumper": [
        {
          "id": "aiConfigJumper.configs",
          "name": "AI Configs"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.5.2"
  }
}
